{
  "productName": "FlipperZero Tool",
  "version": "0.1.0",
  "identifier": "com.giosue.flipperzero-tool",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlipperZero Tool",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "scope": ["$APPDATA/**", "$HOME/**", "$DESKTOP/**", "$DOCUMENTS/**"]
    }
  }
}
